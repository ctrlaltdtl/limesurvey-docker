# LimeSurvey Docker — environment variables
# Run ./setup.sh to generate .env interactively, or copy this file to .env and fill in values manually.
# .env is gitignored — never commit it.
#
# Password rules: min 12 chars, cannot contain: ' \ " # $
# Database/username rules: letters, numbers, and underscores only

MYSQL_ROOT_PASSWORD="change-me-root-password"
MYSQL_DATABASE="limesurvey_db"
MYSQL_USER="lime_user"
MYSQL_PASSWORD="change-me-user-password"
